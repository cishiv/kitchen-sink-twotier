{
  "name": "@twotier/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot run src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "bunx --bun tsc --noEmit",
    "lint": "bunx --bun biome check .",
    "format": "bunx --bun biome format --write .",
    "test": "bun test",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bunx --bun drizzle-kit migrate",
    "db:studio": "bunx --bun drizzle-kit studio",
    "auth:generate": "bunx --bun @better-auth/cli@latest generate --config src/lib/auth.ts --output src/db/schema/auth.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@openrouter/ai-sdk-provider": "^0.4.0",
    "@polar-sh/sdk": "^0.32.0",
    "@twotier/shared": "workspace:*",
    "ai": "^4.0.0",
    "better-auth": "^1.2.7",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.6.13",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.14",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.6.3"
  }
}
