# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgres://twotier:twotier@localhost:5432/twotier

# Auth (Better Auth)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:5173

# Polar (https://polar.sh) — required for /api/billing/* and webhook routes.
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox
POLAR_WEBHOOK_SECRET=
POLAR_SUCCESS_URL=http://localhost:5173/billing/success

# OpenRouter (https://openrouter.ai) — required for any LLM-using service.
OPENROUTER_API_KEY=

# Cloudflare R2 — required for /api/uploads/*.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
