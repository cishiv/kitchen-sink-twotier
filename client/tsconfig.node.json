{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "composite": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist/tsconfig-node",
    "types": ["node"]
  },
  "include": ["vite.config.ts"]
}
